# Docker Compose 会自动读取当前目录下的 .env 文件。
# 可以基于这份模板生成 infra/.env，并按需覆盖默认值。

MYSQL_IMAGE=mysql:8.4
MYSQL_CONTAINER_NAME=mail-manager-mysql
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=mail_manager
MYSQL_USER=mail_manager
MYSQL_PASSWORD=mail_manager
MYSQL_PORT=3306

REDIS_IMAGE=redis:7.4-alpine
REDIS_CONTAINER_NAME=mail-manager-redis
REDIS_HOST=redis
REDIS_PORT=6379

BACKEND_CONTAINER_NAME=mail-manager-backend
BACKEND_PORT=8080
FRONTEND_CONTAINER_NAME=mail-manager-frontend
FRONTEND_PORT=5173

APP_TIMEZONE=Asia/Shanghai
BOOTSTRAP_ENABLED=true

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456

DEFAULT_CLIENT_ID=core-platform
DEFAULT_CLIENT_SECRET=core-platform-secret

JWT_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
ENCRYPTION_SECRET=0123456789abcdef0123456789abcdef
